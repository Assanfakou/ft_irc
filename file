    while ((pos = client.getBuffer().find("\r\n")) != std::string::npos)
    {
        // std::cout << client.getPrefix() << "\n";
        std::cout << "buffer: [" << client.getBuffer().substr(0, pos) << "]" << " length: [" << pos << "]" << std::endl;
